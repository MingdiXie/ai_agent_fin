# Get your key from DeepSeek's API platform
DEEPSEEK_API_KEY=sk-your-key-here

# Clerk authentication
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key
CLERK_JWT_ISSUER=https://your-clerk-domain.clerk.accounts.dev
# Optional: override JWKS URL if needed
CLERK_JWKS_URL=
# Optional: set only if you configure a JWT audience in Clerk
CLERK_JWT_AUDIENCE=

# Optional: override DeepSeek defaults
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# Optional: comma-separated Clerk user IDs that should be treated as paid Basic users
BASIC_USER_IDS=
# Legacy browser IDs for local testing only
BASIC_CLIENT_IDS=

# Optional later: Stripe Checkout for Basic ($9/month)
STRIPE_SECRET_KEY=
STRIPE_BASIC_PRICE_ID=
APP_BASE_URL=http://localhost:5173

# The Python API runs on port 3001 via:
# python3 -m uvicorn server.app:app --reload --port 3001
